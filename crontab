# crontab -e
# Consultar estado MP cada 5 minutos
*/5 * * * * /path/to/venv/bin/python /path/to/manage.py consultar_estado_mp

# Limpiar compras expiradas cada 15 minutos
*/15 * * * * /path/to/venv/bin/python /path/to/manage.py limpiar_compras_expiradas

# Limpiar logs viejos una vez por semana
0 3 * * 0 /path/to/venv/bin/python /path/to/manage.py limpiar_logs

# Limpiar passrecovery cada hora
0 * * * * /path/to/venv/bin/python /path/to/manage.py limpiar_passrecovery